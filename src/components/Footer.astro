---
const year = new Date().getFullYear();
---

<footer data-pagefind-ignore>
	<div class="footer-inner">
		<p>
			&copy; {year} Tim Dennis ·
			<a href="/rss.xml">RSS</a> ·
			<a href="/search">Search</a> ·
			<a href="https://github.com/jt14den" target="_blank" rel="noopener">GitHub</a> ·
			<a href="https://www.linkedin.com/in/jtimdennis/" target="_blank" rel="noopener">LinkedIn</a> ·
			<a href="https://orcid.org/0000-0001-6632-3812" target="_blank" rel="noopener">ORCID</a>
		</p>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em 4em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.footer-inner {
		max-width: var(--max-w);
		margin: 0 auto;
	}
	p {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin: 0;
	}
	a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
