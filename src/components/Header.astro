---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<a class="skip-link" href="#main-content">Skip to main content</a>
<header data-pagefind-ignore>
	<div class="header-inner">
		<div class="site-title">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<nav aria-label="Main navigation">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/notes">Notes</HeaderLink>
			<HeaderLink href="/programs">Programs</HeaderLink>
			<HeaderLink href="/case-studies">Case Studies</HeaderLink>
			<HeaderLink href="/impact">Impact</HeaderLink>
			<HeaderLink href="/governance">Governance</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.header-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
	}
	.site-title {
		padding: 0.75em 0 0.5em;
		font-size: 1.25rem;
		font-weight: 700;
	}
	.site-title a {
		text-decoration: none;
		color: rgb(var(--black));
		letter-spacing: -0.01em;
	}
	.site-title a:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0;
		padding: 0 0 0.25em;
	}
	nav :global(a) {
		padding: 0.35em 0.65em 0.35em 0;
		font-size: 1rem;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-right: 0.1em;
		white-space: nowrap;
	}
	nav :global(a:hover) {
		color: rgb(var(--black));
	}
	nav :global(a.active) {
		color: rgb(var(--black));
		border-bottom-color: var(--accent);
		font-weight: 600;
	}
	@media (max-width: 600px) {
		nav {
			flex-wrap: nowrap;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			padding-bottom: 0.5em;
		}
		nav::-webkit-scrollbar { display: none; }
		nav :global(a) {
			font-size: 0.9rem;
			padding-right: 0.5em;
		}
	}
</style>
