---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
---

<a class="skip-link" href="#main-content">Skip to main content</a>
<header data-pagefind-ignore>
	<div class="header-inner">
		<div class="site-title">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<nav aria-label="Main navigation">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/notes">Notes</HeaderLink>
			<HeaderLink href="/programs">Programs</HeaderLink>
			<HeaderLink href="/case-studies">Case Studies</HeaderLink>
			<HeaderLink href="/impact">Impact</HeaderLink>
			<HeaderLink href="/governance">Governance</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<button type="button" id="search-open" class="search-btn" aria-label="Search (press /)" aria-keyshortcuts="/">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
				Search
			</button>
		</nav>
	</div>
</header>

<dialog id="search-dialog" class="search-dialog" data-pagefind-ignore aria-label="Site search">
	<Search id="pf-modal" />
</dialog>

<script is:inline>
	(function () {
		const dlg = document.getElementById('search-dialog');
		const openBtn = document.getElementById('search-open');
		function open() {
			if (dlg && typeof dlg.showModal === 'function' && !dlg.open) {
				dlg.showModal();
				setTimeout(function () {
					const i = document.getElementById('pf-modal-input');
					if (i) i.focus();
				}, 30);
			}
		}
		if (openBtn) openBtn.addEventListener('click', open);
		document.addEventListener('keydown', function (e) {
			const el = document.activeElement;
			const tag = el && el.tagName;
			const typing = tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || (el && el.isContentEditable);
			if (e.key === '/' && !typing) {
				e.preventDefault();
				open();
			}
		});
		// click on backdrop closes (Esc closes natively)
		if (dlg) dlg.addEventListener('click', function (e) { if (e.target === dlg) dlg.close(); });
	})();
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.header-inner {
		max-width: var(--max-w);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
	}
	.site-title {
		padding: 0.75em 0 0.5em;
		font-size: 1.25rem;
		font-weight: 700;
	}
	.site-title a {
		text-decoration: none;
		color: rgb(var(--black));
		letter-spacing: -0.01em;
	}
	.site-title a:hover {
		color: var(--accent);
	}
	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0;
		padding: 0 0 0.25em;
	}
	nav :global(a) {
		padding: 0.35em 0.65em 0.35em 0;
		font-size: 1rem;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-right: 0.1em;
		white-space: nowrap;
	}
	nav :global(a:hover) {
		color: rgb(var(--black));
	}
	nav :global(a.active) {
		color: rgb(var(--black));
		border-bottom-color: var(--accent);
		font-weight: 600;
	}
	.search-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.3em;
		padding: 0.35em 0.65em 0.35em 0;
		font-size: 1rem;
		font-family: inherit;
		color: rgb(var(--gray-dark));
		background: none;
		border: none;
		border-bottom: 2px solid transparent;
		cursor: pointer;
		white-space: nowrap;
	}
	.search-btn:hover { color: rgb(var(--black)); }
	.search-dialog {
		width: min(640px, 92vw);
		padding: 1rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		box-shadow: var(--box-shadow);
		margin-top: 12vh;
	}
	.search-dialog::backdrop {
		background: rgba(0, 0, 0, 0.35);
	}
	@media (max-width: 600px) {
		nav {
			flex-wrap: nowrap;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			padding-bottom: 0.5em;
		}
		nav::-webkit-scrollbar { display: none; }
		nav :global(a) {
			font-size: 0.9rem;
			padding-right: 0.5em;
		}
	}
</style>
