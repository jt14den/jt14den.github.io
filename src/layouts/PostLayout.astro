---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description?: string;
	date?: Date;
	pubDate?: Date;
	updated?: Date;
	tags?: string[];
	type?: string;
	canonicalUrl?: string;
	externalUrl?: string;
	/** Set to true for notes that promoted to blog — shows "From Notes" badge */
	fromNotes?: boolean;
	/** Set to true for notes pages (adjusts back link) */
	isNote?: boolean;
}

const {
	title,
	description,
	date,
	pubDate,
	updated,
	tags = [],
	type = 'essay',
	canonicalUrl,
	externalUrl,
	fromNotes = false,
	isNote = false,
} = Astro.props;

const effectiveDate = date ?? pubDate;
const pageTitle = `${title} — ${SITE_TITLE}`;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;

// Canonical: for crossposts, point to external source; otherwise this page
const canonical = type === 'crosspost' && canonicalUrl ? canonicalUrl : pageUrl;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={pageTitle}
			description={description}
			canonicalUrl={canonical}
		/>
	</head>
	<body>
		<Header />
		<main id="main-content" data-pagefind-body>
			<article>
				<header class="post-header">
					<!-- Badges -->
					<div class="post-badges" style="margin-bottom: 0.5rem; display: flex; gap: 0.4rem; flex-wrap: wrap;">
						{type === 'crosspost' && (
							<span class="type-badge crosspost">Originally published elsewhere</span>
						)}
						{type === 'linkpost' && (
							<span class="type-badge linkpost">Link</span>
						)}
						{fromNotes && (
							<span class="type-badge from-notes">From Notes</span>
						)}
					</div>

					<h1>{title}</h1>

					<div class="post-date">
						{effectiveDate && <FormattedDate date={effectiveDate} />}
						{updated && (
							<span style="margin-left: 0.75rem; font-style: italic;">
								Updated: <FormattedDate date={updated} />
							</span>
						)}
					</div>

					{tags.length > 0 && (
						<ul class="tags">
							{tags.map((tag) => (
								<li class="tag">
									<a href={`/blog/tags/${tag.toLowerCase().replace(/\s+/g, '-')}/`}>{tag}</a>
								</li>
							))}
						</ul>
					)}
				</header>

				<!-- Crosspost notice -->
				{type === 'crosspost' && canonicalUrl && (
					<div class="crosspost-notice">
						This is a summary. Read the full post at{' '}
						<a href={canonicalUrl} target="_blank" rel="noopener">{canonicalUrl}</a>.
					</div>
				)}

				<!-- Linkpost external link -->
				{type === 'linkpost' && externalUrl && (
					<p style="font-size: 0.95rem; margin-bottom: 1.5rem;">
						→ <a href={externalUrl} target="_blank" rel="noopener">{externalUrl}</a>
					</p>
				)}

				<div class="prose">
					<slot />
				</div>

				<footer class="post-footer">
					<div>
						<a href={isNote ? '/notes/' : '/blog/'} style="font-size: 0.9rem; color: rgb(var(--gray)); text-decoration: none;">
							← {isNote ? 'All notes' : 'All posts'}
						</a>
					</div>
					<a
						class="share-linkedin"
						href={linkedInShareUrl}
						target="_blank"
						rel="noopener"
						aria-label="Share on LinkedIn"
					>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
						Share on LinkedIn
					</a>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>
