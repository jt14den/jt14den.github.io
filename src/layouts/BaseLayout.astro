---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	/** Pass true when title is already fully formed (no site name appended) */
	fullTitle?: boolean;
}

const { title, description, fullTitle = false } = Astro.props;
const pageTitle = fullTitle ? title : `${title} - ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
