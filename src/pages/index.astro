---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const websiteSchema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"name": "Tim Dennis",
			"url": "https://www.tim-dennis.com",
			"description": SITE_DESCRIPTION,
			"author": { "@type": "Person", "name": "Tim Dennis" }
		},
		{
			"@type": "Person",
			"name": "Tim Dennis",
			"jobTitle": "Director, UCLA Library Data Science Center",
			"affiliation": {
				"@type": "EducationalOrganization",
				"name": "University of California, Los Angeles"
			},
			"url": "https://www.tim-dennis.com",
			"sameAs": [
				"https://orcid.org/0000-0001-6632-3812",
				"https://scholar.google.com/citations?user=RpiRBrAAAAAJ",
				"https://github.com/jt14den",
				"https://www.linkedin.com/in/jtimdennis/"
			],
			"knowsAbout": [
				"Open Science",
				"Research Data Management",
				"Research Data Infrastructure",
				"Data Governance",
				"Library Leadership"
			]
		}
	]
};

// Latest 5 published blog posts
const blogPosts = (await getCollection('blog'))
	.filter((p) => p.data.status === 'published')
	.sort((a, b) => {
		const da = (a.data.date ?? a.data.pubDate)?.valueOf() ?? 0;
		const db = (b.data.date ?? b.data.pubDate)?.valueOf() ?? 0;
		return db - da;
	})
	.slice(0, 5);

// Latest 3 notes + blog-promoted notes
const allNotes = (await getCollection('notes'))
	.filter((n) => n.data.status === 'published')
	.sort((a, b) => ((b.data.date)?.valueOf() ?? 0) - ((a.data.date)?.valueOf() ?? 0))
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Tim Dennis | Research Data Infrastructure & Academic Library Leadership" description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<div class="home-intro">
				<p>
					I'm Tim Dennis. I've spent 26 years in the UC system building research data
					infrastructure that keeps running after the grant ends, after the staff
					turns over, after the priorities shift.
				</p>
				<p>
					I run the UCLA Library Data Science Center. This is where I write about what that
					work actually takes.
				</p>
			</div>

			<section class="home-section">
				<h2>Recent writing</h2>
				{blogPosts.length > 0 ? (
					<ul class="post-list">
						{blogPosts.map((post) => {
							const d = post.data.date ?? post.data.pubDate;
							return (
								<li>
									<p class="post-meta">
										{d && <FormattedDate date={d} />}
										{post.data.type === 'crosspost' && (
											<span class="type-badge crosspost">Crosspost</span>
										)}
										{post.data.type === 'linkpost' && (
											<span class="type-badge linkpost">Link</span>
										)}
									</p>
									<p class="post-title">
										<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									</p>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
								</li>
							);
						})}
					</ul>
				) : (
					<p style="color: rgb(var(--gray)); font-size: 0.95rem;">No posts yet.</p>
				)}
				<p style="margin-top: 1rem; font-size: 0.9rem;">
					<a href="/blog/">All posts →</a>
				</p>
			</section>

			{allNotes.length > 0 && (
				<section class="home-section">
					<h2>Notes</h2>
					<ul class="post-list">
						{allNotes.map((note) => (
							<li>
								<p class="post-meta">
									{note.data.date && <FormattedDate date={note.data.date} />}
									{note.data.type === 'linkpost' && (
										<span class="type-badge linkpost">Link</span>
									)}
									{note.data.type === 'crosspost' && (
										<span class="type-badge crosspost">Crosspost</span>
									)}
								</p>
								<p class="post-title">
									<a href={`/notes/${note.id}/`}>{note.data.title}</a>
								</p>
								{note.data.description && (
									<p class="post-desc">{note.data.description}</p>
								)}
							</li>
						))}
					</ul>
					<p style="margin-top: 1rem; font-size: 0.9rem;">
						<a href="/notes/">All notes →</a>
					</p>
				</section>
			)}

			<section class="home-section">
				<h2>Work</h2>
				<div class="home-links">
					<a href="/programs/">Programs</a>
					<a href="/impact/">Impact</a>
					<a href="/case-studies/">Case Studies</a>
					<a href="/scholarship/">Scholarship</a>
					<a href="/talks-grants/">Talks & Grants</a>
					<a href="/governance/">Governance</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
