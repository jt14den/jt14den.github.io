---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Tim Dennis</h1>
			<h2>Director, UCLA Library Data Science Center</h2>
			
			<p>
				I lead research data services and open science initiatives at UCLA Library, with 26 years 
				of experience in the UC system. My work focuses on building capacity for reproducible research, 
				data management, and open science practices across the academic community.
			</p>

			<h3>Current Focus</h3>
			<ul>
				<li>Leading major grant initiatives in open science education and infrastructure</li>
				<li>Scaling research data services and computational training programs</li>
				<li>Building partnerships across the UC system and beyond</li>
				<li>Advancing library leadership in the digital research landscape</li>
			</ul>

			<h3>Recent Highlights</h3>
			<ul>
				<li><strong>IMLS Grant PI</strong> - "Lessons for Librarians in Open Science" ($237K)</li>
				<li><strong>Sloan Foundation Co-PI</strong> - UC Open Source Program Office Network ($1.85M)</li>
				<li><strong>UC Carpentries</strong> - Founded and scaled to 500+ annual learners</li>
				<li><strong>DataSquad</strong> - Developed peer consulting model for research support</li>
			</ul>

			<p>
				Explore my <a href="/projects">major projects</a>, read my <a href="/blog">recent posts</a> 
				on library technology and open science, or <a href="/about">learn more about my background</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
