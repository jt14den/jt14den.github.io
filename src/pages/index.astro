---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} fullTitle={true}>
	<h1>Tim Dennis</h1>
	<p class="lead">
		Director, UCLA Library Data Science Center — building durable research infrastructure,
		open science education, and workforce capacity across the UC system.
	</p>

	<nav class="page-links">
		<a href="/programs">Programs</a>
		<a href="/impact">Impact</a>
		<a href="/case-studies">Case Studies</a>
		<a href="/governance">Governance</a>
	</nav>

	<p>
		With 26 years of experience in the UC system, I lead research data services, open science
		initiatives, and computational training at UCLA Library. My work spans data infrastructure,
		restricted data environments, peer consulting models, and system-wide education programs.
	</p>

	<p>
		Explore my <a href="/scholarship">scholarship and citable outputs</a>, review
		<a href="/talks-grants">talks and grant awards</a>, or read about the specific
		<a href="/case-studies">research partnerships</a> that shaped this work.
	</p>
</BaseLayout>

<style>
	h1 {
		margin-bottom: 0.25rem;
	}
	.lead {
		font-size: 1.1rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 2rem;
	}
	.page-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.page-links a {
		display: inline-block;
		padding: 0.5rem 1.25rem;
		background: rgb(var(--gray-light));
		border-radius: 4px;
		text-decoration: none;
		font-weight: 600;
		color: rgb(var(--black));
		transition: background 0.15s ease;
	}
	.page-links a:hover {
		background: var(--accent);
		color: white;
	}
</style>
