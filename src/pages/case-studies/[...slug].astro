---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

export async function getStaticPaths() {
	const studies = await getCollection('caseStudies');
	return studies.map((study) => ({
		params: { slug: study.id },
		props: study,
	}));
}

type Props = CollectionEntry<'caseStudies'>;

const study = Astro.props;
const { Content, headings } = await render(study);
const { title, description, partner, year, outcomes, tags } = study.data;
---

<StarlightPage
	frontmatter={{
		title,
		description,
		tableOfContents: headings.length > 1,
	}}
	headings={headings}
>
	<article>
		<header class="study-header">
			<div class="meta">
				{partner && <span class="partner">{partner}</span>}
				{year && <span class="year">{year}</span>}
			</div>
			{
				outcomes.length > 0 && (
					<div class="outcomes-block">
						<h3>Key outcomes</h3>
						<ul>
							{outcomes.map((o) => (
								<li>{o}</li>
							))}
						</ul>
					</div>
				)
			}
		</header>

		<div class="sl-markdown-content">
			<Content />
		</div>
	</article>

	<p class="back"><a href="/case-studies/">← All case studies</a></p>
</StarlightPage>

<style>
	.study-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.meta {
		display: flex;
		gap: 1rem;
		margin-bottom: 1.25rem;
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}
	.partner {
		font-style: italic;
	}
	.outcomes-block h3 {
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
	}
	.outcomes-block ul {
		margin: 0;
		padding-left: 1.25rem;
	}
	.outcomes-block li {
		font-size: 0.95rem;
		margin-bottom: 0.25rem;
	}
	.back {
		margin-top: 2rem;
		font-size: 0.9rem;
	}
</style>
