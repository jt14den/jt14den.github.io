---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const studies = await getCollection('caseStudies');
	return studies.map((study) => ({
		params: { slug: study.id },
		props: study,
	}));
}

type Props = CollectionEntry<'caseStudies'>;

const study = Astro.props;
const { Content } = await render(study);
const { title, description, partner, year, outcomes, tags } = study.data;
---

<BaseLayout title={title} description={description}>
	<article data-pagefind-body>
		<header class="study-header">
			<h1>{title}</h1>
			<div class="meta">
				{partner && <span class="partner">{partner}</span>}
				{year && <span class="year">{year}</span>}
			</div>
			{outcomes.length > 0 && (
				<div class="outcomes-block">
					<h3>Key outcomes</h3>
					<ul>
						{outcomes.map((o) => (
							<li>{o}</li>
						))}
					</ul>
				</div>
			)}
			{tags.length > 0 && (
				<ul class="tags" style="margin-top: 1rem;">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>
			)}
		</header>

		<div class="prose">
			<Content />
		</div>
	</article>

	<p class="back"><a href="/case-studies/">← All case studies</a></p>
</BaseLayout>

<style>
	h1 { font-size: 1.8rem; margin-bottom: 0.75rem; }
	.study-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.meta {
		display: flex;
		gap: 1rem;
		margin-bottom: 1.25rem;
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}
	.partner { font-style: italic; }
	.outcomes-block h3 {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgb(var(--gray));
		margin-bottom: 0.75rem;
	}
	.outcomes-block ul { margin: 0; padding: 0; list-style: none; }
	.outcomes-block li {
		font-size: 1.05rem;
		font-weight: 700;
		color: rgb(var(--black));
		padding: 0.5rem 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.outcomes-block li:last-child { border-bottom: none; }
	.back { margin-top: 2rem; font-size: 0.9rem; }
</style>
