---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const studies = (await getCollection('caseStudies')).sort(
	(a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);
---

<BaseLayout title="Case Studies" description="Concrete research partnerships — including a pipeline reduced from 318 to 2 minutes and a $5M follow-on grant — showing how infrastructure work translates into measurable research outcomes.">
	<h1>Case Studies</h1>
	<p class="page-intro">
		These are not success stories in the marketing sense. They are accounts of specific
		partnerships — what we built, what changed, and why the model matters.
	</p>

	<ul class="card-list">
		{studies.map((study) => (
			<li>
				<a href={`/case-studies/${study.id}/`}>
					<h2>{study.data.title}</h2>
					{study.data.partner && (
						<p style="font-size: 0.875rem; color: rgb(var(--gray)); margin: 0 0 0.5rem;">
							{study.data.partner}
						</p>
					)}
					<p>{study.data.description}</p>
					{study.data.outcomes.length > 0 && (
						<ul class="outcomes-preview">
							{study.data.outcomes.slice(0, 2).map((o) => (
								<li>{o}</li>
							))}
						</ul>
					)}
				</a>
			</li>
		))}
	</ul>
</BaseLayout>

<style>
	h1 { font-size: 1.8rem; margin-bottom: 0.5rem; }
	.outcomes-preview {
		list-style: none;
		padding: 0.75rem 0 0;
		margin: 0.5rem 0 0;
		border-top: 1px solid rgb(var(--gray-light));
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.outcomes-preview li {
		font-size: 0.95rem;
		font-weight: 600;
		color: rgb(var(--gray-dark));
	}
</style>
