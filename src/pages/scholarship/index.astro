---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const outputs = (await getCollection('scholarship')).sort(
	(a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);

const typeLabels: Record<string, string> = {
	journal: 'Journal article',
	'book-chapter': 'Book chapter',
	report: 'Report',
	dataset: 'Dataset',
	curriculum: 'Curriculum',
	other: 'Output',
};
---

<BaseLayout title="Scholarship" description="Publications, reports, curricula, and other citable research outputs.">
	<h1>Scholarship</h1>
	<p>
		Publications, reports, funded curricula, and other citable outputs from my work in research data
		services, open science, and library education.
	</p>

	<ul class="item-list">
		{outputs.map((output) => (
			<li>
				<div class="section-heading">{typeLabels[output.data.type] ?? 'Output'}</div>
				<h2>{output.data.title}</h2>
				<div class="meta">
					{output.data.venue && <span>{output.data.venue}</span>}
					{output.data.year && <span>{output.data.year}</span>}
				</div>
				<p>{output.data.description}</p>
				{output.data.doi && (
					<a
						class="doi"
						href={`https://doi.org/${output.data.doi}`}
						target="_blank"
						rel="noopener"
					>
						DOI: {output.data.doi}
					</a>
				)}
			</li>
		))}
	</ul>
</BaseLayout>

<style>
	h1 { font-size: 1.8rem; margin-bottom: 1rem; }
	h2 { font-size: 1.05rem; margin: 0 0 0.25rem; }
	.meta {
		display: flex;
		gap: 1rem;
		font-size: 0.875rem;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
	}
	p { margin: 0 0 0.5rem; color: rgb(var(--gray-dark)); font-size: 0.95rem; }
	.doi { font-size: 0.875rem; font-family: monospace; }
</style>
