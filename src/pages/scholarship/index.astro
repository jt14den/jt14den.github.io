---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_AUTHOR } from '../../consts';

const outputs = (await getCollection('scholarship')).sort(
	(a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);

const typeLabels: Record<string, string> = {
	journal: 'Journal article',
	'book-chapter': 'Book chapter',
	report: 'Report',
	dataset: 'Dataset',
	curriculum: 'Curriculum',
	other: 'Output',
};

// Map each output type to a schema.org type for JSON-LD structured data
const schemaType: Record<string, string> = {
	journal: 'ScholarlyArticle',
	'book-chapter': 'Chapter',
	report: 'Report',
	dataset: 'Dataset',
	curriculum: 'LearningResource',
	other: 'CreativeWork',
};

// --- citation helpers (offline, no dependencies; run at build) ---
// Authors are stored "Family, Given". Convert for display / initials.
function toDisplayName(name: string): string {
	const [family, given] = name.split(',').map((s) => s.trim());
	return given ? `${given} ${family}` : family;
}
function apaName(name: string): string {
	const [family, given] = name.split(',').map((s) => s.trim());
	if (!given) return family;
	const initials = given
		.split(/\s+/)
		.map((g) => `${g[0].toUpperCase()}.`)
		.join(' ');
	return `${family}, ${initials}`;
}
function apaCitation(o: (typeof outputs)[number]): string {
	const a = o.data.authors;
	const authorStr = a.length <= 2 ? a.map(apaName).join(' & ') : `${apaName(a[0])} et al.`;
	const year = o.data.year ? ` (${o.data.year}).` : '';
	const venue = o.data.venue ? ` ${o.data.venue}.` : '';
	const doi = o.data.doi ? ` https://doi.org/${o.data.doi}` : '';
	return `${authorStr}${year} ${o.data.title}.${venue}${doi}`.replace(/\s+/g, ' ').trim();
}
const bibtexType: Record<string, string> = {
	journal: 'article',
	'book-chapter': 'incollection',
	report: 'techreport',
	dataset: 'misc',
	curriculum: 'misc',
	other: 'misc',
};
function bibtex(o: (typeof outputs)[number]): string {
	const type = bibtexType[o.data.type] ?? 'misc';
	const key = `${(o.data.authors[0] ?? 'dennis').split(',')[0].replace(/\s+/g, '').toLowerCase()}${o.data.year ?? ''}`;
	const lines = [
		`@${type}{${key},`,
		`  title  = {${o.data.title}},`,
		`  author = {${o.data.authors.join(' and ')}},`,
	];
	if (o.data.year) lines.push(`  year   = {${o.data.year}},`);
	if (o.data.venue)
		lines.push(`  ${type === 'incollection' ? 'booktitle' : 'howpublished'} = {${o.data.venue}},`);
	if (o.data.doi) {
		lines.push(`  doi    = {${o.data.doi}},`);
		lines.push(`  url    = {https://doi.org/${o.data.doi}},`);
	}
	lines.push('}');
	return lines.join('\n');
}

const authorUrl = Astro.site?.href ?? 'https://www.tim-dennis.com/';
const scholarshipJsonLd = {
	'@context': 'https://schema.org',
	'@graph': outputs.map((output) => ({
		'@type': schemaType[output.data.type] ?? 'CreativeWork',
		name: output.data.title,
		author: output.data.authors.length
			? output.data.authors.map((n) => ({ '@type': 'Person', name: toDisplayName(n) }))
			: { '@type': 'Person', name: SITE_AUTHOR, url: authorUrl },
		...(output.data.description && { description: output.data.description }),
		...(output.data.year && { datePublished: String(output.data.year) }),
		...(output.data.venue && {
			isPartOf: { '@type': 'CreativeWork', name: output.data.venue },
		}),
		...(output.data.doi && {
			identifier: { '@type': 'PropertyValue', propertyID: 'DOI', value: output.data.doi },
			sameAs: `https://doi.org/${output.data.doi}`,
			url: `https://doi.org/${output.data.doi}`,
		}),
	})),
};
---

<BaseLayout title="Scholarship" description="Publications, reports, curricula, and other citable research outputs.">
	<script type="application/ld+json" slot="head" is:inline set:html={JSON.stringify(scholarshipJsonLd)} />

	<h1>Scholarship</h1>
	<p>
		Publications, reports, funded curricula, and other citable outputs from my work in research data
		services, open science, and library education.
	</p>

	<ul class="item-list">
		{outputs.map((output) => (
			<li>
				<div class="section-heading">{typeLabels[output.data.type] ?? 'Output'}</div>
				<h2>{output.data.title}</h2>
				<div class="meta">
					{output.data.venue && <span>{output.data.venue}</span>}
					{output.data.year && <span>{output.data.year}</span>}
				</div>
				<p>{output.data.description}</p>
				{output.data.doi && (
					<a
						class="doi"
						href={`https://doi.org/${output.data.doi}`}
						target="_blank"
						rel="noopener"
					>
						DOI: {output.data.doi}
					</a>
				)}
				{output.data.authors.length > 0 && (
					<details class="cite">
						<summary>Cite this</summary>
						<p class="apa">{apaCitation(output)}</p>
						<pre class="bibtex">{bibtex(output)}</pre>
					</details>
				)}
			</li>
		))}
	</ul>
</BaseLayout>

<style>
	h1 { font-size: 1.8rem; margin-bottom: 1rem; }
	h2 { font-size: 1.05rem; margin: 0 0 0.25rem; }
	.meta {
		display: flex;
		gap: 1rem;
		font-size: 0.875rem;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
	}
	p { margin: 0 0 0.5rem; color: rgb(var(--gray-dark)); font-size: 0.95rem; }
	.doi { font-size: 0.875rem; font-family: monospace; }
	.cite { margin-top: 0.5rem; font-size: 0.85rem; }
	.cite summary { cursor: pointer; color: var(--accent); }
	.cite .apa { margin: 0.5rem 0; color: rgb(var(--gray-dark)); }
	.cite .bibtex {
		background: rgb(var(--gray-light));
		padding: 0.6rem 0.8rem;
		border-radius: 6px;
		overflow-x: auto;
		font-size: 0.8rem;
		white-space: pre;
	}
</style>
