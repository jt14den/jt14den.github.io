---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const outputs = (await getCollection('scholarship')).sort(
	(a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);

const typeLabels: Record<string, string> = {
	journal: 'Journal article',
	'book-chapter': 'Book chapter',
	report: 'Report',
	dataset: 'Dataset',
	curriculum: 'Curriculum',
	other: 'Output',
};
---

<StarlightPage
	frontmatter={{
		title: 'Scholarship',
		description: 'Publications, reports, curricula, and other citable research outputs.',
	}}
>
	<p>
		Publications, reports, funded curricula, and other citable outputs from my work in research data
		services, open science, and library education.
	</p>

	<ul class="output-list">
		{
			outputs.map((output) => (
				<li>
					<div class="output-type">{typeLabels[output.data.type] ?? 'Output'}</div>
					<h2>{output.data.title}</h2>
					<div class="meta">
						{output.data.venue && <span>{output.data.venue}</span>}
						{output.data.year && <span>{output.data.year}</span>}
					</div>
					<p>{output.data.description}</p>
					{output.data.doi && (
						<a
							class="doi"
							href={`https://doi.org/${output.data.doi}`}
							target="_blank"
							rel="noopener"
						>
							DOI: {output.data.doi}
						</a>
					)}
				</li>
			))
		}
	</ul>
</StarlightPage>

<style>
	.output-list {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}
	.output-list li {
		padding: 1.5rem 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.output-list li:last-child {
		border-bottom: none;
	}
	.output-type {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		margin-bottom: 0.25rem;
	}
	h2 {
		font-size: 1.05rem;
		margin: 0 0 0.25rem;
	}
	.meta {
		display: flex;
		gap: 1rem;
		font-size: 0.875rem;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
	}
	p {
		margin: 0 0 0.5rem;
		color: rgb(var(--gray-dark));
		font-size: 0.95rem;
	}
	.doi {
		font-size: 0.875rem;
		font-family: monospace;
	}
</style>
