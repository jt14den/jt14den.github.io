---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const programs = await getCollection('programs');
	return programs.map((program) => ({
		params: { slug: program.id },
		props: program,
	}));
}

type Props = CollectionEntry<'programs'>;

const program = Astro.props;
const { Content } = await render(program);
const { title, description, tags, startYear, collaborators, relatedLinks } = program.data;
---

<BaseLayout title={title} description={description}>
	<article data-pagefind-body>
		<header class="program-header">
			<h1>{title}</h1>
			{startYear && <p class="meta">{startYear}–present</p>}
			<p class="description">{description}</p>
			{tags.length > 0 && (
				<ul class="tags">
					{tags.map((tag) => (
						<li>{tag}</li>
					))}
				</ul>
			)}
		</header>

		<div class="prose">
			<Content />
		</div>

		{(collaborators.length > 0 || relatedLinks.length > 0) && (
			<aside class="program-meta">
				{collaborators.length > 0 && (
					<div>
						<h3>Collaborators</h3>
						<ul>
							{collaborators.map((c) => (
								<li>{c}</li>
							))}
						</ul>
					</div>
				)}
				{relatedLinks.length > 0 && (
					<div>
						<h3>Links</h3>
						<ul>
							{relatedLinks.map((link) => (
								<li>
									<a href={link.url} target="_blank" rel="noopener">
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				)}
			</aside>
		)}
	</article>

	<p class="back"><a href="/programs/">← All programs</a></p>
</BaseLayout>

<style>
	h1 { font-size: 1.8rem; margin-bottom: 0.5rem; }
	.program-header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.meta { color: rgb(var(--gray)); font-size: 0.9rem; margin: 0 0 0.75rem; }
	.description { font-size: 1.05rem; color: rgb(var(--gray-dark)); margin: 0 0 1rem; }
	.program-meta {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
		display: flex;
		gap: 3rem;
		flex-wrap: wrap;
	}
	.program-meta h3 {
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		margin-bottom: 0.5rem;
	}
	.program-meta ul { list-style: none; padding: 0; margin: 0; }
	.program-meta li { font-size: 0.9rem; margin-bottom: 0.25rem; }
	.back { margin-top: 2rem; font-size: 0.9rem; }
</style>
