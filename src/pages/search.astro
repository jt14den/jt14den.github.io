---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Search from '../components/Search.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Search — ${SITE_TITLE}`} description="Search posts and notes." />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<h1 style="font-size: 1.4rem; margin-bottom: 1.5rem;">Search</h1>
			<Search id="pf-page" autofocus placeholder="Search posts, notes, programs, scholarship…" />
		</main>
		<Footer />
	</body>
</html>
